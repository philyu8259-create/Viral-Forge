PORT=8787

# Local development defaults to SQLite. Alibaba Cloud FC should use DATA_STORE=tablestore.
DATA_STORE=sqlite
SQLITE_PATH=./data/viralforge.sqlite

# mock for prototype; china_live/live currently use Qwen text and Seedream images.
AI_PROVIDER_MODE=china_live

# Provider keys live only on the backend.
QWEN_API_KEY=
SEEDREAM_API_KEY=
# Alias accepted by the Seedream provider for Volcengine Ark keys.
ARK_API_KEY=

# Optional provider overrides.
QWEN_TEXT_MODEL=qwen-plus
SEEDREAM_IMAGE_MODEL=doubao-seedream-4-5-251128
SEEDREAM_IMAGES_URL=https://ark.cn-beijing.volces.com/api/v3/images/generations
SEEDREAM_SIZE_PORTRAIT=1440x2560

# Tablestore production settings for Alibaba Cloud FC.
TABLESTORE_ENDPOINT=
TABLESTORE_INSTANCE=
TABLESTORE_TABLE_NAME=viralforge_records
TABLESTORE_ACCESS_KEY_ID=
TABLESTORE_ACCESS_KEY_SECRET=

# Optional object storage settings for later.
OBJECT_STORAGE_BUCKET=

# local_development trusts StoreKit-verified client transactions for simulator/sandbox MVP work.
# For production, switch this path to Apple App Store Server API verification.
IAP_VERIFICATION_MODE=local_development
APP_STORE_SERVER_ENVIRONMENT=sandbox
APP_STORE_SERVER_ISSUER_ID=
APP_STORE_SERVER_KEY_ID=
APP_STORE_SERVER_BUNDLE_ID=com.phil.viralforge
APP_STORE_SERVER_PRIVATE_KEY_PATH=
# Alternative to PRIVATE_KEY_PATH. Use escaped line breaks if you store the key directly.
APP_STORE_SERVER_PRIVATE_KEY=
